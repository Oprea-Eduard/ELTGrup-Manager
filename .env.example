# PostgreSQL (local / docker / server extern)
# Runtime connection:
DATABASE_URL="postgresql://postgres:<PASSWORD>@127.0.0.1:5432/postgres"

# Direct connection pentru migrate/seed (poate fi identica cu DATABASE_URL):
DIRECT_URL="postgresql://postgres:<PASSWORD>@127.0.0.1:5432/postgres"

# Seed behavior:
# safe (default) -> refresh RBAC only, fara date demo
# bootstrap -> creeaza un singur SUPER_ADMIN initial pe o baza fara useri
# demo -> insereaza/reimprospateaza datele minimale de onboarding; blocat pe baze migrate/live
SEED_MODE="safe"

# Required only for SEED_MODE=bootstrap:
SEED_BOOTSTRAP_EMAIL=""
SEED_BOOTSTRAP_FIRST_NAME=""
SEED_BOOTSTRAP_LAST_NAME=""
SEED_BOOTSTRAP_PASSWORD=""

# Required only for SEED_MODE=demo:
# Must be set to the exact value RUN_DEMO_SEED.
SEED_DEMO_CONFIRM=""
# Explicit demo password, shared by the seeded demo users.
SEED_PASSWORD=""

# Variabile folosite de scriptul de migrare (nu sunt necesare la runtime):
# OLD_DATABASE_URL=""
# NEW_DATABASE_URL=""
# NEW_DIRECT_URL=""

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="schimba-cu-o-cheie-lunga-si-sigura"
STORAGE_BUCKET="eltgrup-documents"
STORAGE_ENDPOINT="https://s3.example.com"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAP_PROVIDER_TOKEN=""

# ── eFactura FGO (ANAF) ──────────────────────────────────
# Activeaza integrarea cu sistemul eFactura al ANAF
EFATURA_ENABLED="false"
# "sandbox" (default) sau "production"
FGO_ENV="sandbox"
# Formatul de transmisie: "JSON" (default) sau "XML"
FGO_FORMAT="JSON"
# URL-uri OAuth si API (au valori implicite bazate pe FGO_ENV)
# FGO_OAUTH_URL=""
# FGO_API_URL=""
# Credentiale OAuth (obligatorii in productie)
# FGO_CLIENT_ID=""
# FGO_CLIENT_SECRET=""
